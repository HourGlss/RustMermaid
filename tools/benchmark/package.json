{
  "name": "selkie-benchmark",
  "version": "1.0.0",
  "type": "module",
  "description": "Performance benchmark for Selkie vs Mermaid.js",
  "scripts": {
    "benchmark": "node benchmark.mjs",
    "benchmark:browser": "node browser-performance.mjs",
    "acceptance:large": "node large-flowchart-benchmark.mjs && node browser-performance.mjs",
    "phase6": "node phase6-trace.mjs",
    "eval:flowchart-summary": "node flowchart-eval-summary.mjs",
    "gate:flowchart-eval": "node flowchart-eval-summary.mjs check-target baselines/phase8-flowchart-eval-target.json",
    "gate:performance": "node phase6-trace.mjs && node phase6-trace.mjs check-budgets baselines/phase7-performance-budgets.json reports/phase6/summary.json",
    "test:phase6": "node phase6-trace.test.mjs",
    "test:phase8": "node flowchart-eval-summary.test.mjs",
    "test:browser-performance": "node browser-performance.test.mjs",
    "test:editor": "node editor-interaction.test.mjs"
  },
  "dependencies": {
    "jsdom": "^24.0.0",
    "mermaid": "^11.4.0",
    "playwright": "^1.40.0"
  }
}
